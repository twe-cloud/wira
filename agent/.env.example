# --- Identity ---
OWNER_NAME=Craig
ASSISTANT_NAME=Wira

# --- Brain ---
# "chatgpt" (default, uses your ChatGPT subscription — no API key needed)
# "anthropic" (Claude API), "openai" (GPT API), or "ollama" (local, free)
LLM_PROVIDER=chatgpt

# Only needed if LLM_PROVIDER=anthropic. https://console.anthropic.com
# ANTHROPIC_API_KEY=

# Only needed if LLM_PROVIDER=openai. https://platform.openai.com
# OPENAI_API_KEY=

# Optional: override the model.
# Defaults: gpt-4o (chatgpt) / claude-sonnet-4-6 (anthropic) / gpt-4o-mini (openai) / llama3.2:3b (ollama)
# LLM_MODEL=gpt-4o

# Only used when LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434

# Max length of a reply (tokens)
MAX_TOKENS=400

# --- Behaviour ---
# Reply in group chats too? Default false = direct messages only.
REPLY_TO_GROUPS=false

# Comma-separated phone numbers (digits only, no +). Empty = reply to everyone.
# ALLOWLIST=15551234567,447700900000

# --- Approval mode ---
# "auto-trusted" (default, recommended): drafts a reply for new contacts,
#   auto-sends to numbers in AUTO_SEND_TO.
# "draft":   never auto-sends. Every reply is queued in drafts.db for review.
# "auto-all": send every reply. Fast but riskier — only for contacts you trust.
APPROVAL_MODE=auto-trusted
# AUTO_SEND_TO=15551234567,447700900000

# --- Voice training ---
# Paste a handful of your own recent WhatsApp replies, one per line.
# Wira mirrors the rhythm, tone, emoji use, and length.
# VOICE_SAMPLES="haha yes\nsure, sending now 🤝\nWill loop back tomorrow AM"
# Or point at a file:
# VOICE_SAMPLES_FILE=/home/craig/.wira/voice.txt

# Identify as an AI assistant when asked? (recommended: true)
DISCLOSE_AI=true

# --- Storage (defaults are fine) ---
# SESSION_DB_PATH=session.sqlite3
# MEMORY_DB_PATH=~/.wira/memory.db
# MAX_HISTORY_MESSAGES=20
