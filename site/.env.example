# Stripe (server-side, used by netlify/functions/*)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WHSEC=whsec_REPLACE_ME

# Public site URL (used for Stripe redirects). Netlify auto-sets URL in
# production, so SITE_URL only needs to be set in local dev or for previews.
SITE_URL=http://localhost:3001
