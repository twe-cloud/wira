{
  "name": "product-site",
  "private": true,
  "version": "0.1.0",
  "description": "Marketing site + onboarding for the WhatsApp AI assistant product.",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3001",
    "sync-brand": "node scripts/sync-brand.mjs",
    "build": "npm run sync-brand && tsc --noEmit && vite build",
    "preview": "vite preview --port=3001",
    "lint": "tsc --noEmit",
    "netlify:dev": "netlify dev",
    "netlify:deploy": "netlify deploy --build",
    "netlify:deploy:prod": "netlify deploy --build --prod"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.10.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "stripe": "^17.5.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
